nano process_log.sh
#!/bin/bash

# Check if log file is provided
if [ $# -ne 1 ]; then
    echo "Usage: $0 <logfile>"
    exit 1
fi

logfile=$1

# Check if file exists
if [ ! -f "$logfile" ]; then
    echo "File $logfile does not exist."
    exit 1
fi

# Regex for a valid IPv4 address
ip_regex="([0-9]{1,3}\.){3}[0-9]{1,3}"

# Process the log file
while IFS= read -r line
do
    # Extract IP addresses
    ips=$(echo "$line" | grep -oE "$ip_regex")
    valid_ips=""
    for ip in $ips; do
        # Validate each octet is <= 255
        if [[ $ip =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]]; then
            valid=true
            for i in {1..4}; do
                octet=$(echo "$ip" | cut -d. -f$i)
                if ((octet > 255)); then
                    valid=false
                    break
                fi
            done
            if $valid; then
                valid_ips="$valid_ips $ip"
            fi
        fi
    done

    # Extract date-time stamps (common format: YYYY-MM-DD HH:MM:SS)
    datetime=$(echo "$line" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}')

    # Extract error messages (assuming "error" is in the line)
    error_msg=$(echo "$line" | grep -i "error")

    # Display if any valid IP, datetime, and error message found
    if [ -n "$valid_ips" ] || [ -n "$datetime" ] || [ -n "$error_msg" ]; then
        echo "Line: $line"
        [ -n "$valid_ips" ] && echo "  IP(s): $valid_ips"
        [ -n "$datetime" ] && echo "  Date-Time: $datetime"
        [ -n "$error_msg" ] && echo "  Error: $error_msg"
        echo "------------------------"
    fi
done < "$logfile"

