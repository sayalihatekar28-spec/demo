## TERRAFORM AWS EC2 INSTANCE DEPLOYMENT
Region: ap-south-1
Instance Type: t3.micro
Security Group: web-sg
Key Pair: terraQ2
STEP 1: Create project directory
mkdir terraform-ec2
cd terraform-ec2
STEP 2: Create Terraform files
nano main.tf
nano outputs.tf
nano user_data.sh
STEP 3: main.tf (UPDATED & CORRECT)
terraform {
  required_version = ">= 1.3.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}
provider "aws" {
  region = "ap-south-1"
}
resource "aws_security_group" "web_sg" {
  name        = "web-sg-01"
  description = "Allow SSH and HTTP traffic"
  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }
  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}
resource "aws_instance" "web_server" {
  ami           = "ami-05d2d839d4f73aafb"(put yours ami id)
  instance_type = "t3.micro"
  key_name      = "terraQ2"
  vpc_security_group_ids = [aws_security_group.web_sg.id]
