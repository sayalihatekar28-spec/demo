#!/bin/bash

# Check for required arguments
if [ $# -ne 3 ]; then
    echo "Usage: $0 <directory_to_monitor> <size_limit_MB> <log_filename>"
    exit 1
fi

dir_to_monitor=$1
size_limit=$2
filename=$3
USERNAME=$(whoami)
logfile="/home/$USERNAME/$filename"

# Check if directory exists
if [ ! -d "$dir_to_monitor" ]; then
    echo "Directory $dir_to_monitor does not exist."
    exit 1
fi

# Get current size of directory in MB
dir_size=$(du -sm "$dir_to_monitor" | awk '{print $1}')

# Compare with threshold
if (( dir_size > size_limit )); then
    timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo "[$timestamp] WARNING: Directory $dir_to_monitor size is ${dir_size}MB, exceeds limit of ${size_limit}MB." >> "$logfile"
    echo "Warning logged in $logfile"
else
    echo "Directory size ${dir_size}MB is within limit."
fi


