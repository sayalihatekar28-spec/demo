Q5
Monitor CPU usage and log values.

msc1@spccsd-pc:~$ nano  cpu_monitor.sh
#!/bin/bash

# Check for number of iterations
if [ -z "$1" ]; then
    echo "Enter number of iterations:"
    read iterations
else
    iterations=$1
fi

logfile="cpu_usage_log.txt"
> "$logfile"

count=1

while [ $count -le $iterations ]
do
    # Extract CPU idle and make sure it's a valid number
    cpu_idle=$(top -bn1 | grep "Cpu(s)" | awk '{print $8}' | tr -d ',%' | sed 's/[^0-9.]//g')

    # Skip iteration if cpu_idle is empty or invalid
    if [ -z "$cpu_idle" ]; then
        echo "Iteration $count: Could not read CPU usage, skipping."
        count=$((count + 1))
        continue
    fi

    # Calculate CPU usage
    cpu_usage=$(echo "100 - $cpu_idle" | bc -l)

    # Skip logging if CPU usage < 10%
    if (( $(echo "$cpu_usage < 10" | bc -l) )); then
        echo "Iteration $count: CPU usage $cpu_usage% < 10%, skipping logging."
        count=$((count + 1))
        continue
    fi

    # Stop monitoring if CPU usage > 90%
    if (( $(echo "$cpu_usage > 90" | bc -l) )); then
        echo "$(date '+%Y-%m-%d %H:%M:%S') CPU Usage: $cpu_usage% (HIGH - stopping)" >> "$logfile"
        break
    fi

    # Log CPU usage
    echo "$(date '+%Y-%m-%d %H:%M:%S') CPU Usage: $cpu_usage%" >> "$logfile"
    echo "Iteration $count: CPU usage $cpu_usage% logged."

    count=$((count + 1))
    sleep 1
done

echo "Monitoring complete. CPU usage logged in $logfile"
cat "$logfile"

