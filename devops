#!/bin/bash

# Check if required arguments are provided
if [ $# -ne 2 ]; then
    echo "Usage: $0 <hostname/IP> <filename>"
    exit 1
fi

host=$1
filename=$2
USERNAME=$(whoami)
logfile="/home/$USERNAME/$filename"

# Get current timestamp
timestamp=$(date "+%Y-%m-%d %H:%M:%S")

# Ping the host (send 1 packet, wait 2 seconds)
if ping -c 1 -W 2 "$host" > /dev/null 2>&1
