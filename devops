Q3 Search all .txt files and count lines containing "error".

msc1@spccsd-pc:~$ nano error_report.sh
#!/bin/bash

# Directory to search (current directory by default)
search_dir="."

# Report file
report_file="error_report.txt"

# Clear report file if it already exists
> "$report_file"

# Find all .txt files recursively and process them
find "$search_dir" -type f -name "*.txt" -print0 | while IFS= read -r -d '' file
do
    # Count lines containing the word "error" (case-insensitive)
    count=$(grep -iwc "error" "$file")

    # Append result to report file
    echo "$file : $count" >> "$report_file"
done

# Display the report
cat "$report_file"


